async function restartPrayerLoop(guildId) {
    if (prayerIntervals.has(guildId)) {
      clearInterval(prayerIntervals.get(guildId));
      prayerIntervals.delete(guildId);
    }
  
    const prayer = await Prayer.findOne({ guildId });
    if (!prayer || !prayer.interval) return; 
  
    const interval = setInterval(async () => {
      const prayerText = getRandomDua();
      try {
        const channel = await client.channels.fetch(prayer.channelId);
        if (channel) {
          const embed = new EmbedBuilder()
            .setColor('#0099ff')
            .setTitle('📿 دعاء')
            .setDescription(prayerText)
            .setTimestamp();
  
          channel.send({ embeds: [embed] });
        }
      } catch (error) {
        console.error(`❌ خطأ في إرسال الدعاء إلى القناة ${prayer.channelId}:`, error);
      }
    }, prayer.interval * 1000);
  
    prayerIntervals.set(guildId, interval);
  }







