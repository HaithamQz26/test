function parseTime(time) {
  if (typeof time !== "string") {
    time = time.toString();
  }
  const match = time.match(/^(\d+)([smh])$/);
  if (!match) {
    throw new Error("❌ يجب كتابة الوقت بصيغة صحيحة، مثل: '10s' أو '5m' أو '1h'.");
  }
  let value = parseInt(match[1]);
  let unit = match[2];
  return unit === "s" ? value : unit === "m" ? value * 60 : value * 3600;
}





