function getRandomQuestion(category = null) {
  const questions = JSON.parse(fs.readFileSync('./questions.json', 'utf8'));

  if (!Array.isArray(questions) || questions.length === 0) return null;

  const filteredQuestions = category ? questions.filter(q => q.category === category) : questions;

  if (filteredQuestions.length === 0) return null;

  return filteredQuestions[Math.floor(Math.random() * filteredQuestions.length)];
}

client.on('interactionCreate', async (interaction) => {
  if (!interaction.isChatInputCommand() && !interaction.isButton()) return;


  if (interaction.isChatInputCommand()) {
      if (interaction.commandName === 'quran_page') {
          let page = interaction.options.getInteger('page') || 1;
          await sendQuranPage(interaction, page);
          return;
      }

      if (interaction.commandName === 'تحويل_للهجرى') {
          const year = interaction.options.getInteger('السنة');
          const month = interaction.options.getInteger('الشهر');
          const day = interaction.options.getInteger('اليوم');

          if (month < 1 || month > 12 || day < 1 || day > 31) {
              return interaction.reply({ content: '❌ يرجى إدخال تاريخ صالح!', ephemeral: true });
          }

          const gregorianDate = moment(`${year}-${month}-${day}`, 'YYYY-MM-DD');
          const hijriDate = gregorianDate.format('iYYYY/iM/iD');

          const embed = new EmbedBuilder()
              .setTitle('📆 تحويل التاريخ إلى الهجري')
              .setColor(0x00AEEF)
              .addFields(
                  { name: '📅 التاريخ الميلادي', value: `${year}-${month}-${day}`, inline: true },
                  { name: '🕌 التاريخ الهجري', value: hijriDate, inline: true }
              )
              .setFooter({ text: 'التاريخ محول باستخدام مكتبة moment-hijri' });

          await interaction.reply({ embeds: [embed] });
          return;
      }

     

      if (interaction.commandName === 'question') {
          const category = interaction.options.getString('category');
          const question = getRandomQuestion(category);

          if (!question) {
              return interaction.reply({ content: '❌ لا توجد أسئلة متاحة في هذه الفئة.', ephemeral: true });
          }

          const embed = new EmbedBuilder()
          .setTitle('❓ سؤال جديد')
          .setDescription(question.question)
          .setColor(0x00AEEF)
          .setFooter({ text: 'اضغط على أحد الأزرار للإجابة' })
          .addFields(
              question.choices.map((choice, index) => ({
                  name: `الاختيار ${index + 1}:`,
                  value: choice,
                  inline: true
              }))
          );
          const buttons = question.choices.map(choice =>
              new ButtonBuilder()
                  .setCustomId(`question_${choice}`)
                  .setLabel(choice)
                  .setStyle(ButtonStyle.Primary)
          );

          const row = new ActionRowBuilder().addComponents(buttons);

          await interaction.reply({ embeds: [embed], components: [row] });
          return;
      }
  }

  
  if (interaction.isButton()) {
      const [prefix, actionOrChoice, pageOrChoice] = interaction.customId.split('_');

      if (prefix === 'quran') {
          let page = parseInt(pageOrChoice);

          if (actionOrChoice === 'next') page++;
          if (actionOrChoice === 'prev') page--;

          if (page < 1) page = 1;
          if (page > 604) page = 604;

          await sendQuranPage(interaction, page, true);
          return;
      }

      if (prefix === 'question') {
        const answer = actionOrChoice;
        const questions = JSON.parse(fs.readFileSync('./questions.json', 'utf8'));
        const question = questions.find(q => q.choices.includes(answer));
    
        if (!question) {
            console.error('Question not found:', answer);
            return interaction.reply({ content: '❌ حدث خطأ: تعذر العثور على السؤال.', ephemeral: true });
        }
    
        const correctAnswer = question.correct_answer;
        const response = answer === correctAnswer ? '✅ **إجابة صحيحة!**' : '❌ **إجابة خاطئة!**';
    

        const updatedRow = new ActionRowBuilder().addComponents(
            question.choices.map(choice =>
                new ButtonBuilder()
                    .setCustomId(`question_${choice}`)
                    .setLabel(choice)
                    .setStyle(ButtonStyle.Primary)
                    .setDisabled(true) 
            )
        );
    
        try {
           
            await interaction.message.edit({
                components: [updatedRow]
            });
    
          
            await interaction.reply({ content: response });
        } catch (error) {
            console.error('Failed to update interaction:', error);
            await interaction.reply({ content: '❌ حدث خطأ أثناء معالجة الإجابة!', ephemeral: true }); 
        }
    }
    
  }
});

async function sendQuranPage(interaction, page, isUpdate = false) {
  const imageUrl = `https://cdn.qurango.net/Sura2/files/mobile/${page}.jpg`;

  const embed = new EmbedBuilder()
      .setTitle(`📖 صفحة ${page} من القرآن الكريم`)
      .setImage(imageUrl)
      .setColor(0x00FF00)
      .setFooter({ text: `استخدم الأزرار للتنقل بين الصفحات.` });

  const row = new ActionRowBuilder()
      .addComponents(
          new ButtonBuilder()
              .setCustomId(`quran_prev_${page}`)
              .setLabel('⬅ الصفحة السابقة')
              .setStyle(ButtonStyle.Secondary)
              .setDisabled(page === 1),
          new ButtonBuilder()
              .setCustomId(`quran_next_${page}`)
              .setLabel('➡ الصفحة التالية')
              .setStyle(ButtonStyle.Primary)
              .setDisabled(page === 604)
      );

  if (isUpdate) {
      await interaction.update({ embeds: [embed], components: [row] });
  } else {
      await interaction.reply({ embeds: [embed], components: [row] });
  }
}





